PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/onboarding
DB_SSL=false

# CORS (cabecera Origin del navegador; incluir esquema http:// o https://, o solo host:puerto y se asume http://)
# Con credentials en fetch, no uses * aquí: lista orígenes explícitos (localhost y 127.0.0.1 son distintos).
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# App URLs
APP_BASE_URL=http://localhost:4000
# URL a la que el servidor redirige tras verificar el token del email.
# Debe apuntar a email_confirm.html del cliente (ajustar el puerto según Live Server).
# Ejemplo: http://localhost:5500/client/pages/email_confirm.html
FRONTEND_AFTER_VERIFY_URL=

# URL pública del API para el cliente estático (vacío = mismo origen, rutas relativas /api/...)
PUBLIC_API_BASE=

# Mail (si no se configura, se usa modo mock y se loguea en consola)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Lutente Onboarding <no-reply@lutente.com>"

# Script de tenant
TENANT_SCRIPT_TIMEOUT_MS=120000
